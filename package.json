{
  "name": "wtt-internship-training",
  "main": "src/index",
  "scripts": {
    "build": "rimraf build/; tsc",
    "postbuild": "npx shx cp -r package*.json .env build/",
    "killnode": "taskkill /im node.exe",
    "prettier:write": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json}'",
    "prettier:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,json}'",
    "prepare": "husky install",
    "exe": "ts-node src/index",
    "exe2": "ts-node src/index2",
    "test": "jest"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.14.191",
    "@types/nodemailer": "^6.4.16",
    "@types/papaparse": "^5.3.7",
    "@types/xml2js": "^0.4.12",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "eslint": "^8.27.0",
    "husky": "^8.0.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "axios-ntlm": "^1.4.2",
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.0.0",
    "jest": "^29.7.0",
    "joi": "^17.7.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.4.1",
    "xml2js": "^0.6.2"
  },
  "nodemonConfig": {
    "watch": [
      "src/"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "endOfLine": "crlf",
    "trailingComma": "all"
  },
  "jest": {
    "silent": false,
    "verbose": true,
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "node_modules/",
      "build/"
    ],
    "setupFilesAfterEnv": [
      "dotenv/config"
    ]
  }
}
